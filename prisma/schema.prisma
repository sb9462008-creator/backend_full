generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  COMPANY_ADMIN
  DISPATCHER
  DRIVER
  CUSTOMER
}

enum DriverStatus {
  AVAILABLE
  BUSY
  OFFLINE
}

enum DeliveryStatus {
  PENDING
  ASSIGNED
  ACCEPTED
  PICKED_UP
  IN_TRANSIT
  NEAR_DESTINATION
  DELIVERED
  FAILED
  RETURNED
  CANCELLED
}

enum OrderStatus {
  PLACED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum NotificationChannel {
  IN_APP
  EMAIL
}

model Tenant {
  id             String           @id @default(uuid()) @db.Uuid
  name           String
  slug           String           @unique
  users          User[]
  drivers        Driver[]
  deliveries     Delivery[]
  products       Product[]
  orders         Order[]
  events         TrackingEvent[]
  locations      DriverLocation[]
  proofs         ProofOfDelivery[]
  notifications  Notification[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model User {
  id              String          @id @default(uuid()) @db.Uuid
  tenantId        String          @db.Uuid
  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  name            String
  email           String          @unique
  passwordHash    String
  role            UserRole
  isActive        Boolean         @default(true)
  notifications   Notification[]
  orders          Order[]         @relation("CustomerOrders")
  createdDeliveries Delivery[]    @relation("DeliveryCreatedBy")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([tenantId, role])
}

model Driver {
  id            String           @id @default(uuid()) @db.Uuid
  tenantId      String           @db.Uuid
  tenant        Tenant           @relation(fields: [tenantId], references: [id])
  userId        String?          @db.Uuid
  name          String
  phone         String
  status        DriverStatus     @default(AVAILABLE)
  deliveries    Delivery[]
  locations     DriverLocation[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([tenantId, status])
}

model Delivery {
  id             String           @id @default(uuid()) @db.Uuid
  tenantId       String           @db.Uuid
  tenant         Tenant           @relation(fields: [tenantId], references: [id])
  trackingCode   String           @unique
  driverId       String?          @db.Uuid
  driver         Driver?          @relation(fields: [driverId], references: [id])
  createdById    String?          @db.Uuid
  createdBy      User?            @relation("DeliveryCreatedBy", fields: [createdById], references: [id])
  pickupAddress  String
  pickupLat      Float
  pickupLng      Float
  pickupGeom     Unsupported("geography(Point, 4326)")?
  dropoffAddress String
  dropoffLat     Float
  dropoffLng     Float
  dropoffGeom    Unsupported("geography(Point, 4326)")?
  status         DeliveryStatus   @default(PENDING)
  scheduledAt    DateTime?
  eta            DateTime?
  assignedAt     DateTime?
  acceptedAt     DateTime?
  pickedUpAt     DateTime?
  deliveredAt    DateTime?
  notes          String?
  events         TrackingEvent[]
  proof          ProofOfDelivery?
  order          Order?
  notifications  Notification[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, driverId])
}

model Product {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @db.Uuid
  tenant       Tenant    @relation(fields: [tenantId], references: [id])
  name         String
  slug         String
  sku          String
  category     String
  brand        String?
  description  String?
  priceCents   Int
  imageUrl     String?
  stock        Int       @default(0)
  isActive     Boolean   @default(true)
  orderItems   OrderItem[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([tenantId, slug])
  @@unique([tenantId, sku])
  @@index([tenantId, category, isActive])
}

model Order {
  id               String      @id @default(uuid()) @db.Uuid
  tenantId         String      @db.Uuid
  tenant           Tenant      @relation(fields: [tenantId], references: [id])
  customerId       String      @db.Uuid
  customer         User        @relation("CustomerOrders", fields: [customerId], references: [id])
  deliveryId       String?     @unique @db.Uuid
  delivery         Delivery?   @relation(fields: [deliveryId], references: [id])
  orderNumber      String      @unique
  status           OrderStatus @default(PLACED)
  totalAmountCents Int
  shippingAddress  String
  shippingLat      Float?
  shippingLng      Float?
  notes            String?
  items            OrderItem[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([tenantId, customerId, createdAt])
  @@index([tenantId, status])
}

model OrderItem {
  id             String    @id @default(uuid()) @db.Uuid
  orderId        String    @db.Uuid
  order          Order     @relation(fields: [orderId], references: [id])
  productId      String    @db.Uuid
  product        Product   @relation(fields: [productId], references: [id])
  quantity       Int
  unitPriceCents Int
  createdAt      DateTime  @default(now())

  @@index([orderId])
  @@index([productId])
}

model TrackingEvent {
  id         String           @id @default(uuid()) @db.Uuid
  tenantId   String           @db.Uuid
  tenant     Tenant           @relation(fields: [tenantId], references: [id])
  deliveryId String           @db.Uuid
  delivery   Delivery         @relation(fields: [deliveryId], references: [id])
  eventType  String
  status     DeliveryStatus?
  message    String?
  latitude   Float?
  longitude  Float?
  createdAt  DateTime         @default(now())

  @@index([tenantId, deliveryId, createdAt])
}

model DriverLocation {
  id         String           @id @default(uuid()) @db.Uuid
  tenantId   String           @db.Uuid
  tenant     Tenant           @relation(fields: [tenantId], references: [id])
  driverId   String           @db.Uuid
  driver     Driver           @relation(fields: [driverId], references: [id])
  latitude   Float
  longitude  Float
  geom       Unsupported("geography(Point, 4326)")?
  recordedAt DateTime         @default(now())

  @@index([tenantId, driverId, recordedAt])
}

model ProofOfDelivery {
  id            String           @id @default(uuid()) @db.Uuid
  tenantId      String           @db.Uuid
  tenant        Tenant           @relation(fields: [tenantId], references: [id])
  deliveryId    String           @unique @db.Uuid
  delivery      Delivery         @relation(fields: [deliveryId], references: [id])
  photoUrl      String?
  recipientName String?
  notes         String?
  otpVerified   Boolean          @default(false)
  createdAt     DateTime         @default(now())
}

model Notification {
  id         String               @id @default(uuid()) @db.Uuid
  tenantId   String               @db.Uuid
  tenant     Tenant               @relation(fields: [tenantId], references: [id])
  userId     String?              @db.Uuid
  user       User?                @relation(fields: [userId], references: [id])
  deliveryId String?              @db.Uuid
  delivery   Delivery?            @relation(fields: [deliveryId], references: [id])
  channel    NotificationChannel  @default(IN_APP)
  type       String
  title      String
  body       String
  isRead     Boolean              @default(false)
  createdAt  DateTime             @default(now())

  @@index([tenantId, createdAt])
}
