NODE_ENV=development
PORT=4000
LOG_LEVEL=info
FORCE_HTTPS=false
TRUST_PROXY_HOPS=1

# Postgres with PostGIS enabled.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hurgelt?schema=public
REDIS_URL=redis://localhost:6379

# Shared auth between frontend and backend.
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d

# Public frontend origin used for CORS, Socket.IO, email links, and redirects.
FRONTEND_URL=http://localhost:3000
HTTPS_CERT_PATH=
HTTPS_KEY_PATH=

PROMETHEUS_PORT=9090
ALERTMANAGER_PORT=9093
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=notifications@hurgelt.local

# Local disk uploads are fine for development.
# In production, prefer mounting persistent storage or replacing with object storage.
UPLOAD_DIR=uploads

# Public storefront tenant that customer-facing pages use.
STOREFRONT_TENANT_SLUG=demo-company

WAREHOUSE_ADDRESS=Hurgelt Warehouse, Ulaanbaatar
WAREHOUSE_LAT=47.9184
WAREHOUSE_LNG=106.9177

OPENAI_API_KEY=
