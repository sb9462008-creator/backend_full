NODE_ENV=production
PORT=8080
LOG_LEVEL=info
FORCE_HTTPS=true
TRUST_PROXY_HOPS=1

# Replace with a production Postgres connection string that has PostGIS enabled.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public

# Replace with your production Redis connection string.
REDIS_URL=redis://default:PASSWORD@HOST:6379

# Use a strong random secret.
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d

# Vercel frontend URL or your custom frontend domain.
FRONTEND_URL=https://your-frontend-domain.vercel.app

# Keep empty when TLS is terminated by your host / load balancer.
HTTPS_CERT_PATH=
HTTPS_KEY_PATH=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=notifications@your-domain.com


# Must point to persistent storage if you keep local disk uploads.
UPLOAD_DIR=uploads

STOREFRONT_TENANT_SLUG=demo-company
WAREHOUSE_ADDRESS=Hurgelt Warehouse, Ulaanbaatar
WAREHOUSE_LAT=47.9184
WAREHOUSE_LNG=106.9177

OPENAI_API_KEY=
